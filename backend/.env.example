# Copia este archivo como ".env" y coloca tus valores reales.
# El archivo ".env" NUNCA se sube a GitHub (debe ir en .gitignore).

# Datos de conexion a PostgreSQL (los que usaste en pgAdmin)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sieducres
DB_USER=postgres
DB_PASSWORD=coloca_aqui_tu_contrasena_de_postgres

# Clave secreta para firmar los JWT.
# Genera una propia con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=coloca_aqui_una_clave_secreta_larga_y_aleatoria

# Algoritmo de firma del JWT (no cambiar salvo que sepas por que)
ALGORITHM=HS256

# Cuantos minutos dura el token antes de expirar
ACCESS_TOKEN_EXPIRE_MINUTES=120
